@startuml C4_Nivel2_Containers
' Diagrama C4 - Nível 2: Containers
' Referência: https://c4model.com
' Usa a biblioteca oficial C4-PlantUML com ícones padrão do modelo C4

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

' =====================================================================
' Título e metadados
' =====================================================================
LAYOUT_WITH_LEGEND()

title Diagrama de Containers — Asteroids Single Player

' =====================================================================
' Atores externos
' =====================================================================
Person(jogador, "Jogador", "Interage com o jogo\nvia teclado")

' =====================================================================
' Fronteira do sistema Asteroids
' =====================================================================
System_Boundary(sistema, "Asteroids Single Player") {

    Container(cliente, "Cliente do Jogo", "Python / Pygame", "Gerencia o loop principal\n(60 FPS), captura entrada\ndo teclado, renderiza sprites\ne reproduz áudio.\n\nArquivos: client/game.py,\nclient/renderer.py,\nclient/controls.py,\nclient/audio.py,\nclient/audio_manager.py")

    Container(nucleo, "Núcleo do Jogo", "Python", "Contém todas as regras\ndo jogo: entidades (nave,\nasteroides, UFO, Freeze),\ncolisões, pontuação,\ncongelamento e ondas.\n\nArquivos: core/world.py,\ncore/entities.py,\ncore/collisions.py,\ncore/commands.py,\ncore/config.py,\ncore/utils.py")

    ContainerDb(assets, "Assets de Áudio", "Arquivos WAV\n(Sistema de Arquivos)", "Sons carregados\nna inicialização:\ntiros, explosões,\nsirenes de UFO\ne empuxo da nave.\n\nPasta: assets/sounds/")
}

' =====================================================================
' Relacionamentos
' =====================================================================
Rel(jogador, cliente, "Pressiona teclas\ne visualiza a tela")
Rel(cliente, nucleo, "Envia PlayerCommand\npor frame / lê estado\ndo mundo (sprites, scores,\nfreeze_timer)")
Rel(cliente, assets, "Carrega arquivos .wav\nna inicialização\n(pygame.mixer)")

@enduml
